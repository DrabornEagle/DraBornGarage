rel='src/AppShell.tsx'; s=read(rel)
s=s.replace("import { HomeScreen } from './screens/HomeScreen';", "import { HomeScreen, PanelMode } from './screens/HomeScreen';")
s=s.replace("import { ServiceType } from './types';", "import { ServiceType, WORKER_ROLES } from './types';")
s=s.replace("  const [newOrderMode, setNewOrderMode] = useState<ServiceType | null>(null);\n", "  const [newOrderMode, setNewOrderMode] = useState<ServiceType | null>(null);\n  const canWork = Boolean(membership && WORKER_ROLES.includes(membership.role));\n  const [staffPanelMode, setStaffPanelMode] = useState<PanelMode>(isAdmin || membership?.role === 'owner' || membership?.role === 'owner_mechanic' ? 'business' : 'mechanic');\n")
s=s.replace("  const openOrders = () => setTab('orders');\n  const openNew = (mode: ServiceType = 'dropoff') => setNewOrderMode(mode);",
"""  const openOrders = () => setTab('orders');
  const openNew = (mode: ServiceType = 'dropoff') => {
    if (!canWork || staffPanelMode !== 'mechanic') return;
    setNewOrderMode(mode);
  };

  useEffect(() => {
    setStaffPanelMode(isAdmin || membership?.role === 'owner' || membership?.role === 'owner_mechanic' ? 'business' : 'mechanic');
  }, [workshop?.id, membership?.role, isAdmin]);""")
s=s.replace("? <HomeScreen onNewOrder={openNew} onOpenOrders={openOrders} />", "? <HomeScreen onNewOrder={openNew} onOpenOrders={openOrders} panelMode={staffPanelMode} onPanelModeChange={setStaffPanelMode} />")
s=s.replace("? <WorkOrdersScreen onNewOrder={() => openNew('dropoff')} />", "? <WorkOrdersScreen onNewOrder={() => openNew('dropoff')} allowNewOrder={canWork && staffPanelMode === 'mechanic'} />")
s=s.replace("      {newOrderMode && !isApprentice && (", "      {newOrderMode && !isApprentice && canWork && staffPanelMode === 'mechanic' && (")
write(rel,s)

rel='src/screens/WorkOrdersScreen.tsx'; s=read(rel)
s=s.replace("export function WorkOrdersScreen({ onNewOrder }: { onNewOrder: () => void }) {", "export function WorkOrdersScreen({ onNewOrder, allowNewOrder }: { onNewOrder: () => void; allowNewOrder: boolean }) {")
s=s.replace("      actionIcon={isApprentice ? undefined : 'add'}\n      onAction={isApprentice ? undefined : onNewOrder}", "      actionIcon={!isApprentice && allowNewOrder ? 'add' : undefined}\n      onAction={!isApprentice && allowNewOrder ? onNewOrder : undefined}")
s=s.replace("{!isApprentice && <PrimaryButton title=\"Yeni Servis Kaydı\" onPress={onNewOrder} />}", "{!isApprentice && allowNewOrder && <PrimaryButton title=\"Yeni Servis Kaydı\" onPress={onNewOrder} />}")
