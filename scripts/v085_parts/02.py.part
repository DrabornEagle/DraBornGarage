s=s.replace("  const toggleStaff = async (member: any) => {", """  const reviewMechanicApplication = (application: MechanicApplication, approve: boolean) => Alert.alert(
    approve ? 'Usta başvurusunu onayla' : 'Usta başvurusunu reddet',
