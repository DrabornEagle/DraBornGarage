{
  "expo": {
    "name": "DraBornGarage",
    "slug": "draborngarage",
    "scheme": "draborngarage",
    "version": "0.7.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "DraBornGarage servis QR kodlarını taramak için kameraya erişsin.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DraBornGarage platform ödeme dekontunu seçebilmek için fotoğraflarına erişsin.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.draborneagle.draborngarage"
    },
    "android": {
      "package": "com.draborneagle.draborngarage",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "draborngarage", "host": "claim" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    }
  }
}
