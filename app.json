{
  "expo": {
    "name": "DraBornGarage",
    "slug": "draborngarage",
    "scheme": "draborngarage",
    "version": "0.8.17",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "DraBornGarage servis QR kodlarını taramak için kameraya erişsin.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DraBornGarage platform ödeme dekontunu seçebilmek için fotoğraflarına erişsin.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7C5CFF",
          "defaultChannel": "draborngarage-chime-v1",
          "sounds": [
            "./assets/sounds/garage_chime.wav",
            "./assets/sounds/garage_pulse.wav",
            "./assets/sounds/garage_alert.wav"
          ],
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.draborneagle.draborngarage"
    },
    "android": {
      "package": "com.draborneagle.draborngarage",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "draborngarage",
              "host": "claim"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    }
  }
}
