{
  "expo": {
    "name": "DraBornGarage",
    "slug": "draborngarage",
    "scheme": "draborngarage",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.draborneagle.draborngarage"
    },
    "android": {
      "package": "com.draborneagle.draborngarage",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "draborngarage",
              "host": "claim"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    }
  }
}
