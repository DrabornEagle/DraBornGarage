{
  "expo": {
    "name": "DraBornGarage",
    "slug": "draborngarage",
    "scheme": "draborngarage",
    "version": "1.0.3",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "androidNavigationBar": {
      "backgroundColor": "#00000000",
      "barStyle": "light-content",
      "contrastEnforced": false
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "DraBornGarage servis QR kodlarını taramak için kameraya erişsin.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DraBornGarage yalnız seçtiğin platform ödeme dekontunu yüklemek için fotoğraflarına erişsin.",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7C5CFF",
          "defaultChannel": "draborngarage-chime-v2",
          "sounds": [
            "./assets/sounds/garage_chime.wav",
            "./assets/sounds/garage_pulse.wav",
            "./assets/sounds/garage_alert.wav"
          ]
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.draborneagle.draborngarage",
      "buildNumber": "20"
    },
    "android": {
      "package": "com.draborneagle.draborngarage",
      "versionCode": 20,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.CALL_PHONE",
        "android.permission.READ_PHONE_STATE",
        "android.permission.READ_SMS",
        "android.permission.SEND_SMS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "draborngarage",
              "host": "claim"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    }
  }
}
